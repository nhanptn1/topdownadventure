[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/character_select.gd" id="1"]
[ext_resource type="Texture2D" path="res://assets/sprites/warrior_idle_side_1.png" id="2"]
[ext_resource type="Texture2D" path="res://assets/sprites/mage_idle_front_1.png" id="3"]

[node name="CharacterSelect" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.1, 0.1, 0.15, 1)

[node name="OverwriteConfirm" type="ConfirmationDialog" parent="."]
title = "Start New Game"
dialog_text = "Starting a new game will overwrite your saved progress. Continue?"
size = Vector2i(360, 130)

[node name="CenterContainer" type="CenterContainer" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
theme_override_constants/separation = 24
alignment = 1

[node name="Title" type="Label" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
horizontal_alignment = 1
theme_override_font_sizes/font_size = 32
text = "Choose Your Character"

[node name="WelcomeLabel" type="Label" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(560, 0)
size_flags_horizontal = 4
theme_override_colors/font_color = Color(0.75, 0.75, 0.85, 1)
theme_override_font_sizes/font_size = 15
horizontal_alignment = 1
autowrap_mode = 2
text = "Escaping the flames of a burning kingdom, a lone warrior or mage rises through 3 perilous realms, gearing up, growing stronger, and battling toward a final showdown with the Dragon Sovereign — with a hidden cave hoarding legendary treasures along the way."

[node name="ContinueButton" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 44)
theme_override_font_sizes/font_size = 18
text = "Continue"
visible = false

[node name="HBoxContainer" type="HBoxContainer" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 40
alignment = 1

[node name="WarriorCard" type="VBoxContainer" parent="CenterContainer/VBoxContainer/HBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="PreviewBox" type="CenterContainer" parent="CenterContainer/VBoxContainer/HBoxContainer/WarriorCard"]
custom_minimum_size = Vector2(230, 230)
layout_mode = 2

[node name="Preview" type="TextureRect" parent="CenterContainer/VBoxContainer/HBoxContainer/WarriorCard/PreviewBox"]
custom_minimum_size = Vector2(225, 220)
layout_mode = 2
texture = ExtResource("2")
expand_mode = 1
stretch_mode = 5

[node name="Name" type="Label" parent="CenterContainer/VBoxContainer/HBoxContainer/WarriorCard"]
layout_mode = 2
horizontal_alignment = 1
theme_override_font_sizes/font_size = 20
text = "Warrior"

[node name="SelectButton" type="Button" parent="CenterContainer/VBoxContainer/HBoxContainer/WarriorCard"]
layout_mode = 2
text = "Select"

[node name="MageCard" type="VBoxContainer" parent="CenterContainer/VBoxContainer/HBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="PreviewBox" type="CenterContainer" parent="CenterContainer/VBoxContainer/HBoxContainer/MageCard"]
custom_minimum_size = Vector2(150, 230)
layout_mode = 2

[node name="Preview" type="TextureRect" parent="CenterContainer/VBoxContainer/HBoxContainer/MageCard/PreviewBox"]
custom_minimum_size = Vector2(129, 207)
layout_mode = 2
texture = ExtResource("3")
expand_mode = 1
stretch_mode = 5

[node name="Name" type="Label" parent="CenterContainer/VBoxContainer/HBoxContainer/MageCard"]
layout_mode = 2
horizontal_alignment = 1
theme_override_font_sizes/font_size = 20
text = "Mage"

[node name="SelectButton" type="Button" parent="CenterContainer/VBoxContainer/HBoxContainer/MageCard"]
layout_mode = 2
text = "Select"

[node name="ControlsPopup" type="CenterContainer" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
visible = false

[node name="PanelBG" type="ColorRect" parent="ControlsPopup"]
custom_minimum_size = Vector2(440, 400)
layout_mode = 2
clip_contents = true
color = Color(0.12, 0.12, 0.18, 0.95)

[node name="Margin" type="MarginContainer" parent="ControlsPopup/PanelBG"]
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 20

[node name="Content" type="VBoxContainer" parent="ControlsPopup/PanelBG/Margin"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="Title" type="Label" parent="ControlsPopup/PanelBG/Margin/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 26
horizontal_alignment = 1
text = "Controls"

[node name="ControlsList" type="Label" parent="ControlsPopup/PanelBG/Margin/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/font_size = 16
theme_override_constants/line_spacing = 8
text = "Move: WASD / Arrow Keys
Sprint: Hold Shift
Attack: Left Click or F
Open Inventory: I  (or click the bag icon)
Quick Slot 1 - Heal Potion: 1
Quick Slot 2 - Throwable: 2
Quick Slot 3 - Buff Potion: 3"

[node name="StartButton" type="Button" parent="ControlsPopup/PanelBG/Margin/Content"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Start Game"

[connection signal="pressed" from="CenterContainer/VBoxContainer/ContinueButton" to="." method="_on_continue_pressed"]
[connection signal="pressed" from="CenterContainer/VBoxContainer/HBoxContainer/WarriorCard/SelectButton" to="." method="_on_warrior_pressed"]
[connection signal="pressed" from="CenterContainer/VBoxContainer/HBoxContainer/MageCard/SelectButton" to="." method="_on_mage_pressed"]
[connection signal="pressed" from="ControlsPopup/PanelBG/Margin/Content/StartButton" to="." method="_on_start_game_pressed"]
[connection signal="confirmed" from="OverwriteConfirm" to="." method="_on_overwrite_confirmed"]
